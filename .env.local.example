# Supabase (required for auth and database)
# Get these from: supabase status (after running supabase start)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-from-supabase-status

# Optional: OpenAI (or other AI provider) for real scoring and prompts
# If not set, the app uses mock responses.
OPENAI_API_KEY=
